rderColor: '#fff',\n    borderWidth: 1\n  },\n  name: `${pName[i]} | ${min[i]}' | ${isGoal[i] ? '⚽ GOAL' : 'Shot'}`\n}));\n\nreturn {\n  backgroundColor: 'transparent',\n  tooltip: {\n    trigger: 'item',\n    formatter: p => p.data?.name\n  },\n  graphic: { elements: pitch },\n  xAxis: { min: 0, max: 600, show: false },\n  yAxis: { min: 0, max: 400, show: false },\n  grid: { left: 0, right: 0, top: 0, bottom: 0 },\n  series: [{\n    type: 'scatter',\n    data: points,\n    symbol: 'circle'\n  }]\n};",
