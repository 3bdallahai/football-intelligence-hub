                      "spec": {
                        "dataset": "football_live",
                        "editorMode": "code",
                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT\r\n    player_name,\r\n    team_name,\r\n    SUM(is_touch) AS touches,\r\n    SUM(is_shot) AS shots,\r\n    SUM(is_goal) AS goals,\r\n    SUM(CASE WHEN type_display_name='Pass'\r\n             AND outcome_type_display_name='Successful' THEN 1 ELSE 0 END) AS passes_completed,\r\n    SUM(CASE WHEN type_display_name='Pass' THEN 1 ELSE 0 END) AS passes_total,\r\n    ROUND(\r\n    SUM(CASE \r\n        WHEN type_display_name='Pass'\r\n         AND outcome_type_display_name='Successful' \r\n        THEN 1 ELSE 0 END)\r\n    * 100.0 / NULLIF(SUM(CASE WHEN type_display_name='Pass' THEN 1 ELSE 0 END),0)\r\n    ,1) AS pass_accuracy,\r\n    ROUND(\r\n        5.0\r\n        + (SUM(is_goal) * 2.0)\r\n        + (SUM(is_shot) * 0.3)\r\n        + (SUM(CASE WHEN type_display_name='Pass'\r\n                    AND outcome_type_display_name='Successful' THEN 1 ELSE 0 END)\r\n           / NULLIF(SUM(CASE WHEN type_display_name='Pass' THEN 1 ELSE 0 END),0) * 2.0)\r\n        + (SUM(CASE WHEN type_display_name IN ('Tackle','Interception','Clearance') THEN 1 ELSE 0 END) * 0.2)\r\n        - (SUM(card_type) * 1.0)\r\n    ,1) AS rating\r\nFROM match_events_live\r\nGROUP BY player_name, team_name\r\nORDER BY rating DESC;",
                        "sql": {
