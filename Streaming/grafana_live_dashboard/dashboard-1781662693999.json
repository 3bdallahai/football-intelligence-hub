                        "rawSql": "SELECT x, y, end_x, end_y, outcome_type_display_name\r\nFROM match_events_live\r\nWHERE type_display_name = 'Pass'\r\n  AND player_name = '$player_name'\r\n  AND end_x IS NOT NULL;",
