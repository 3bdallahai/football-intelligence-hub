                "getOption": "const data = context.panel.data;\n\nconst green = '#4a7c4e';\nconst white = '#ffffff';\n\nconst pitch = [\n  { type: 'rect', shape: { x: 0, y: 0, width: 600, height: 400 }, style: { fill: green, stroke: white, lineWidth: 2 } },\n  { type: 'line', shape: { x1: 300, y1: 0, x2: 300, y2: 400 }, style: { stroke: white, lineWidth: 2 } },\n  { type: 'circle', shape: { cx: 300, cy: 200, r: 60 }, style: { fill: 'none', stroke: white, lineWidth: 2 } },\n  { type: 'circle', shape: { cx: 300, cy: 200, r: 4 }, style: { fill: white } },\n  { type: 'rect', shape: { x: 0, y: 100, width: 110, height: 200 }, style: { fill: 'none', stroke: white, lineWidth: 2 } },\n  { type: 'rect', shape: { x: 490, y: 100, width: 110, height: 200 }, style: { fill: 'none', stroke: white, lineWidth: 2 } },\n  { type: 'rect', shape: { x: 0, y: 150, width: 40, height: 100 }, style: { fill: 'none', stroke: white, lineWidth: 2 } },\n  { type: 'rect', shape: { x: 560, y: 150, width: 40, height: 100 }, style: { fill: 'none', stroke: white, lineWidth: 2 } },\n  { type: 'circle', shape: { cx: 80, cy: 200, r: 3 }, style: { fill: white } },\n  { type: 'circle', shape: { cx: 520, cy: 200, r: 3 }, style: { fill: white } },\n];\n\nconst f = data.series[0]?.fields || [];\n\nconst X = f.find(f => f.name === 'x')?.values?.toArray?.() || [];\nconst Y = f.find(f => f.name === 'y')?.values?.toArray?.() || [];\nconst EX = f.find(f => f.name === 'end_x')?.values?.toArray?.() || [];\nconst EY = f.find(f => f.name === 'end_y')?.values?.toArray?.() || [];\nconst OUT = f.find(f => f.name === 'outcome_type_display_name')?.values?.toArray?.() || [];\nconst pName = f.find(f => f.name === 'player_name')?.values?.toArray?.() || [];\nconst min = f.find(f => f.name === 'minute')?.values?.toArray?.() || [];\n\nconst arrows = [];\n\nfor (let i = 0; i < X.length; i++) {\n  if (EX[i] == null || EY[i] == null) continue;\n\n  const success = OUT[i] === 'Successful';\n\n  // pass line\n  arrows.push({\n    type: 'line',\n    shape: {\n      x1: (X[i] / 100) * 600,\n      y1: (Y[i] / 100) * 400,\n      x2: (EX[i] / 100) * 600,\n      y2: (EY[i] / 100) * 400\n    },\n    style: {\n      stroke: success ? 'rgba(255,255,255,0.85)' : 'rgba(255,80,80,0.6)',\n      lineWidth: success ? 2 : 1.5\n    },\n    z: 10\n  });\n\n  // start point\n  arrows.push({\n    type: 'circle',\n    shape: {\n      cx: (X[i] / 100) * 600,\n      cy: (Y[i] / 100) * 400,\n      r: 2.5\n    },\n    style: { fill: '#ffffff' },\n    z: 20\n  });\n\n  // end point\n  arrows.push({\n    type: 'circle',\n    shape: {\n      cx: (EX[i] / 100) * 600,\n      cy: (EY[i] / 100) * 400,\n      r: 2.5\n    },\n    style: {\n      fill: success ? '#00ff88' : '#ff5555'\n    },\n    z: 20\n  });\n}\n\nreturn {\n  backgroundColor: 'transparent',\n  tooltip: {\n    trigger: 'item',\n    formatter: p => p.data?.name\n  },\n  graphic: {\n    elements: [...pitch, ...arrows]\n  },\n  xAxis: { min: 0, max: 600, show: false },\n  yAxis: { min: 0, max: 400, show: false },\n  grid: { left: 0, right: 0, top: 0, bottom: 0 },\n  series: []\n};",
