        ) AS clean_name

    FROM FOOTBALL_BRONZE.RAW.BRONZE_PLAYERS

),

market AS (

    SELECT DISTINCT
        player_name,

        LOWER(
            REGEXP_REPLACE(
                TRANSLATE(player_name,
            'ÁÀÄÂÃÅáàäâãåÇçÉÈËÊéèëêÍÌÏÎíìïîÑñÓÒÖÔÕóòöôõÚÙÜÛúùüûÝýÿŘřŽžŠšŁłĐđĆćČč',
