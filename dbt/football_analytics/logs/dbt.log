WITH market_values AS (

    SELECT *
    FROM FOOTBALL_SILVER.TRANSFORMED_TRANSFORMED.stg_market_values

),

matched AS (

    SELECT
        market_player_name,
        player_name AS stats_player_name
    FROM FOOTBALL_SILVER.TRANSFORMED_TRANSFORMED.int_player_name_match

    WHERE name_sim > 87
      AND team_sim > 85

),

dim_season AS (

    SELECT *
    FROM FOOTBALL_GOLD.TRANSFORMED_MART.dim_season

)

SELECT

    MD5(
        UPPER(
            TRIM(
                COALESCE(
                    m.stats_player_name,
                    mv.player_name
                )
            )
        )
    ) AS player_key,

    ds.season_key,

    mv.player_name AS market_player_name,

    mv.club,

    mv.valuation_date,

    mv.age,

    mv.market_value_eur

FROM market_values mv

LEFT JOIN matched m
    ON mv.player_name = m.market_player_name

LEFT JOIN dim_season ds
    ON mv.season = ds.season
