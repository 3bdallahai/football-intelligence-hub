    as (

/*
  fact_outfield_stats
  Grain: one row per outfield player × season × club × competition
  Source: stg_players (filtered to non-GK positions: FW, MF, DF, etc.)

  Outfield-specific columns that do NOT exist in GK data:
    goals, assists, goal_contributions,
    non_penalty_goals, penalty_goals, penalty_attempts,
    goals_per_90, assists_per_90, goal_contributions_per_90,
    non_penalty_goals_per_90, non_penalty_goal_contributions_per_90,
    total_shots, shots_on_target, shots_on_target_pct,
    shots_per_90, shots_on_target_per_90,
    goals_per_shot, goals_per_shot_on_target,
    minutes_per_substitution, unused_substitute_matches,
    team_goals_while_on_pitch,
    fouls_drawn, offsides, crosses, interceptions,
    tackles_won, penalties_won
*/

WITH outfield AS (

    SELECT *
    FROM FOOTBALL_SILVER.TRANSFORMED_TRANSFORMED.stg_players
    WHERE UPPER(TRIM(player_position)) != 'GK'

),

dim_season AS (

    SELECT *
    FROM FOOTBALL_GOLD.TRANSFORMED_MART.dim_season

)

SELECT

    -- ── KEYS ────────────────────────────────────────────────────────────────
    MD5(UPPER(TRIM(player_name)))   AS player_key,
    MD5(UPPER(TRIM(club)))          AS club_key,
    ds.season_key,

    -- ── DEGENERATE DIMENSIONS ────────────────────────────────────────────────
    player_name,
    season,
    club,
    competition,
    player_age,

    -- ── PLAYING TIME ─────────────────────────────────────────────────────────
    matches_played,
    matches_started,
    minutes_played,
    full_90s_played,
    minutes_per_match,
    minutes_percentage,
    minutes_per_start,
    full_matches_completed,
    minutes_per_substitution,
    unused_substitute_matches,
    points_per_match,

    -- ── GOAL CONTRIBUTIONS ───────────────────────────────────────────────────
    goals,
    assists,
    goal_contributions,
    non_penalty_goals,
    penalty_goals,
    penalty_attempts,

    -- ── PER 90 RATES ─────────────────────────────────────────────────────────
    goals_per_90,
    assists_per_90,
    goal_contributions_per_90,
    non_penalty_goals_per_90,
    non_penalty_goal_contributions_per_90,

    -- ── SHOOTING ─────────────────────────────────────────────────────────────
    total_shots,
    shots_on_target,
    shots_on_target_pct,
    shots_per_90,
    shots_on_target_per_90,
    goals_per_shot,
    goals_per_shot_on_target,

    -- ── TEAM IMPACT ──────────────────────────────────────────────────────────
    team_goals_while_on_pitch,
    team_goals_conceded_while_on_pitch,
    goal_difference_on_pitch,
    goal_difference_per_90,
    on_off_difference,

    -- ── DEFENSIVE / MISC ─────────────────────────────────────────────────────
    fouls_committed,
    fouls_drawn,
    offsides,
    crosses,
    interceptions,
    tackles_won,
    penalties_won,
    penalties_conceded,
    own_goals,

    -- ── DISCIPLINE ───────────────────────────────────────────────────────────
    yellow_cards,
    red_cards,

    -- ── SALARY ───────────────────────────────────────────────────────────────
    weekly_salary_gbp,
    weekly_salary_eur,
    weekly_salary_usd,
    annual_salary_gbp,
    annual_salary_eur,
    annual_salary_usd

FROM outfield

LEFT JOIN dim_season ds
    ON outfield.season = ds.season
    )

