[0m05:24:50.469667 [debug] [Thread-2 (]: On model.football_analytics.int_player_name_match: create or replace transient table FOOTBALL_SILVER.TRANSFORMED_TRANSFORMED.int_player_name_match
    
    
    
    as (WITH players AS (

    SELECT DISTINCT
        player_name,

        LOWER(
            REGEXP_REPLACE(
                UNICODE_NORMALIZE(player_name, 'NFKD'),
                '\\p{M}',
                ''
            )
        ) AS clean_name

    FROM FOOTBALL_BRONZE.RAW.BRONZE_PLAYERS

),

market AS (

    SELECT DISTINCT
        player_name,

        LOWER(
            REGEXP_REPLACE(
                UNICODE_NORMALIZE(player_name, 'NFKD'),
                '\\p{M}',
                ''
            )
        ) AS clean_name

    FROM FOOTBALL_BRONZE.RAW.BRONZE_MARKET_VALUES

),

pairs AS (

    SELECT

        p.player_name AS player_from_players,
        m.player_name AS player_from_market,

        -- ─────────────────────────────────────────────
        -- TOKEN SPLITTING
        -- ─────────────────────────────────────────────

        SPLIT_PART(p.clean_name, ' ', 1) AS p_first,
        SPLIT_PART(p.clean_name, ' ', -1) AS p_last,

        SPLIT_PART(m.clean_name, ' ', 1) AS m_first,
        SPLIT_PART(m.clean_name, ' ', -1) AS m_last,

        -- ─────────────────────────────────────────────
        -- LAST NAME SIMILARITY (MOST IMPORTANT)
        -- ─────────────────────────────────────────────

        JAROWINKLER_SIMILARITY(
            SPLIT_PART(p.clean_name, ' ', -1),
            SPLIT_PART(m.clean_name, ' ', -1)
        ) AS last_name_sim,

        -- ─────────────────────────────────────────────
        -- FIRST NAME MATCH (STRICT)
        -- ─────────────────────────────────────────────

        CASE
            WHEN SPLIT_PART(p.clean_name, ' ', 1)
               = SPLIT_PART(m.clean_name, ' ', 1)
            THEN 1 ELSE 0
        END AS first_name_match,

        -- ─────────────────────────────────────────────
        -- FULL STRING SIMILARITY (SECONDARY SIGNAL)
        -- ─────────────────────────────────────────────

        JAROWINKLER_SIMILARITY(p.clean_name, m.clean_name) AS full_sim

    FROM players p

    CROSS JOIN market m

    -- 🔥 BLOCKING (IMPORTANT PERFORMANCE + ACCURACY BOOST)
    WHERE LEFT(p.clean_name, 3) = LEFT(m.clean_name, 3)

),

scored AS (

    SELECT *,

        -- ─────────────────────────────────────────────
        -- FINAL WEIGHTED SCORE
        -- ─────────────────────────────────────────────
        (
            first_name_match * 0.5
            +
            last_name_sim * 0.5
        ) AS final_score

    FROM pairs

),

filtered AS (

    SELECT *

    FROM scored

    -- 🔥 STRICTER THRESHOLD (prevents false matches like Oliver)
    WHERE final_score >= 0.88

),

ranked AS (

    SELECT *,

        ROW_NUMBER() OVER (
            PARTITION BY player_from_players
            ORDER BY final_score DESC
        ) AS rn

    FROM filtered

)

SELECT
    player_from_players,
    player_from_market,
    final_score,
    first_name_match,
    last_name_sim,
    full_sim

FROM ranked

WHERE rn = 1
    )

