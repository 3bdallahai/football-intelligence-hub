    a.yellow_cards,
    a.red_cards,
    a.fouls_committed,
    a.points_per_match,
    a.goal_difference_per_90,
    a.on_off_difference,
    a.minutes_played

FROM aggregated a

JOIN FOOTBALL_GOLD.TRANSFORMED_MART.dim_player dp
