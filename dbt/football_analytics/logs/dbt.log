[0m04:47:04.766146 [debug] [Thread-2 (]: On model.football_analytics.int_player_name_match: create or replace transient table FOOTBALL_SILVER.TRANSFORMED_TRANSFORMED.int_player_name_match
    
    
    
    as (WITH players AS (

    SELECT DISTINCT
        player_name,

        -- 1. NORMALIZED NAME (remove accents, lowercase, clean)
        LOWER(
            REGEXP_REPLACE(
                UNICODE_NORMALIZE(player_name, 'NFKD'),
                '[^a-z0-9 ]',
                ''
            )
        ) AS clean_name

    FROM FOOTBALL_BRONZE.RAW.BRONZE_PLAYERS

),

market AS (

    SELECT DISTINCT
        player_name,

        LOWER(
            REGEXP_REPLACE(
                UNICODE_NORMALIZE(player_name, 'NFKD'),
                '[^a-z0-9 ]',
                ''
            )
        ) AS clean_name

    FROM FOOTBALL_BRONZE.RAW.BRONZE_MARKET_VALUES

),

matches AS (

    SELECT

        p.player_name AS player_from_players,
        m.player_name AS player_from_market,

        JAROWINKLER_SIMILARITY(p.clean_name, m.clean_name) AS similarity_score,

        -- create stable matching key
        MD5(p.clean_name) AS player_key_players,
        MD5(m.clean_name) AS player_key_market

    FROM players p

    CROSS JOIN market m

    WHERE JAROWINKLER_SIMILARITY(p.clean_name, m.clean_name) >= 0.90

),

ranked AS (

    SELECT *,

        ROW_NUMBER() OVER (
            PARTITION BY player_from_players
            ORDER BY similarity_score DESC
        ) AS rn

    FROM matches

)

SELECT
    player_from_players,
    player_from_market,
    similarity_score,
    player_key_players,
    player_key_market

FROM ranked

WHERE rn = 1
    )

