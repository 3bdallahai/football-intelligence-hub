[0m05:20:42.435174 [debug] [Thread-2 (]: On model.football_analytics.int_player_name_match: create or replace transient table FOOTBALL_SILVER.TRANSFORMED_TRANSFORMED.int_player_name_match
    
    
    
    as (pairs AS (

    SELECT

        p.player_name AS player_from_players,
        m.player_name AS player_from_market,

        p.current_club AS player_team,
        m.club        AS market_team,

        -- ─────────────────────────────
        -- CLEAN NAMES
        -- ─────────────────────────────

        LOWER(REGEXP_REPLACE(
            UNICODE_NORMALIZE(p.player_name, 'NFKD'),
            '\\p{M}', ''
        )) AS p_clean,

        LOWER(REGEXP_REPLACE(
            UNICODE_NORMALIZE(m.player_name, 'NFKD'),
            '\\p{M}', ''
        )) AS m_clean

    FROM FOOTBALL_BRONZE.RAW.BRONZE_PLAYERS p

    CROSS JOIN FOOTBALL_BRONZE.RAW.BRONZE_MARKET_VALUES m

    -- BLOCKING (keep for performance)
    WHERE LEFT(p.player_name, 3) = LEFT(m.player_name, 3)

),

scored AS (

    SELECT *,

        -- ─────────────────────────────
        -- NAME SIMILARITY
        -- ─────────────────────────────

        JAROWINKLER_SIMILARITY(p_clean, m_clean) AS name_sim,

        -- ─────────────────────────────
        -- TEAM MATCH FEATURE
        -- ─────────────────────────────

        CASE
            WHEN p.player_team IS NOT NULL
             AND m.market_team IS NOT NULL
             AND LOWER(p.player_team) = LOWER(m.market_team)
            THEN 1 ELSE 0
        END AS team_match,

        -- ─────────────────────────────
        -- TEAM SIMILARITY (optional soft signal)
        -- ─────────────────────────────

        JAROWINKLER_SIMILARITY(
            LOWER(COALESCE(p.player_team, '')),
            LOWER(COALESCE(m.market_team, ''))
        ) AS team_sim

    FROM pairs

),

final_scoring AS (

    SELECT *,

        -- ─────────────────────────────
        -- FINAL WEIGHTED SCORE
        -- ─────────────────────────────

        (
            name_sim * 0.75
            +
            team_sim * 0.15
            +
            team_match * 0.10
        ) AS final_score

    FROM scored

),

filtered AS (

    SELECT *

    FROM final_scoring

    -- stricter threshold now (because we added team signal)
    WHERE final_score >= 0.87

),

ranked AS (

    SELECT *,

        ROW_NUMBER() OVER (
            PARTITION BY player_from_players
            ORDER BY final_score DESC
        ) AS rn

    FROM filtered

)

SELECT
    player_from_players,
    player_from_market,

    p_clean AS players_clean_name,
    m_clean AS market_clean_name,

    player_team,
    market_team,

    final_score,
    name_sim,
    team_sim,
    team_match

FROM ranked

WHERE rn = 1
    )

