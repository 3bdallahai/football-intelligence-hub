    as (

/*
  fact_goalkeeper_stats
  Grain: one row per goalkeeper × season × club × competition
  Source: stg_players (filtered to GK position)
  
  GK-specific columns that do NOT exist in outfield data:
    goals_conceded, goals_conceded_per_90, shots_on_target_against,
    saves, save_percentage, wins, draws, losses,
    clean_sheets, clean_sheet_percentage,
    penalties_faced, penalty_goals_conceded
  
  Shared playing-time / discipline columns are included here too
  so each fact table is self-contained for analytics.
*/

WITH gk AS (

    SELECT *
    FROM FOOTBALL_SILVER.TRANSFORMED_TRANSFORMED.stg_players
    WHERE UPPER(TRIM(player_position)) = 'GK'

),

dim_season AS (

    SELECT *
    FROM FOOTBALL_GOLD.TRANSFORMED_MART.dim_season

)

SELECT

    -- ── KEYS ────────────────────────────────────────────────────────────────
    MD5(UPPER(TRIM(player_name)))   AS player_key,
    MD5(UPPER(TRIM(club)))          AS club_key,
    ds.season_key,

    -- ── DEGENERATE DIMENSIONS ────────────────────────────────────────────────
    player_name,
    season,
    club,
    competition,
    player_age,

    -- ── PLAYING TIME ─────────────────────────────────────────────────────────
    matches_played,
    matches_started,
    minutes_played,
    full_90s_played,
    minutes_per_match,
    minutes_percentage,
    minutes_per_start,
    full_matches_completed,
    points_per_match,

    -- ── GK CORE: CONCEDING & SAVING ──────────────────────────────────────────
    goals_conceded,
    goals_conceded_per_90,
    shots_on_target_against,
    saves,
    save_percentage,

    -- ── GK CORE: RESULTS ─────────────────────────────────────────────────────
    wins,
    draws,
    losses,
    clean_sheets,
    clean_sheet_percentage,

    -- ── GK CORE: PENALTIES ───────────────────────────────────────────────────
    penalties_faced,
    penalty_goals_conceded,
    penalties_conceded,         -- penalties given away (fouls in box)

    -- ── TEAM IMPACT ──────────────────────────────────────────────────────────
    team_goals_conceded_while_on_pitch,
    goal_difference_on_pitch,
    goal_difference_per_90,
    on_off_difference,

    -- ── DISCIPLINE ───────────────────────────────────────────────────────────
    yellow_cards,
    red_cards,
    fouls_committed,
    own_goals,

    -- ── SALARY ───────────────────────────────────────────────────────────────
    weekly_salary_gbp,
    weekly_salary_eur,
    weekly_salary_usd,
    annual_salary_gbp,
    annual_salary_eur,
    annual_salary_usd

FROM gk

LEFT JOIN dim_season ds
    ON gk.season = ds.season
    )

/* {"app": "dbt", "dbt_version": "1.11.11", "profile_name": "football_analytics", "target_name": "dev", "node_id": "model.football_analytics.fact_goalkeeper_stats"} */;
